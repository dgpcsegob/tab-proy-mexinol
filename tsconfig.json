{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "node",

    "resolveJsonModule": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false,

    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,

    "jsx": "react-jsx"
  },

  "include": ["src"]
}